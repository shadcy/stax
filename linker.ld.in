/* ============================================================================
 * TIOS — linker.ld
 * GNU ld linker script for the ARM Versatile Platform Baseboard (versatilepb).
 * ============================================================================ */

#include "memory_map.h"

/* Entry point: _start is defined in startup.s */
ENTRY(_start)

/* --------------------------------------------
 * MEMORY — declare the physical regions available to the linker.
 * -------------------------------------------- */
MEMORY
{
    RAM (rwx) : ORIGIN = KERNEL_EXEC_ADDR, LENGTH = 32M
}

/* --------------------------------------------
 * SECTIONS — describe how to pack input sections into output sections
 * -------------------------------------------- */
SECTIONS
{
    /* ---- Code and read-only data ---- */
    .text : {
        _text_start = .;
        *(.text._start)         /* startup.s _start FIRST */
        *(.text*)               /* all other .text input sections */
        *(.rodata*)             /* read-only data */
        *(.glue_7)
        *(.glue_7t)
        *(.vfp11_veneer)
        *(.v4_bx)
        . = ALIGN(4);
        _text_end = .;
    } > RAM

    /* ---- Initialised data ---- */
    .data : {
        . = ALIGN(4);
        _data_start = .;
        *(.data*)
        . = ALIGN(4);
        _data_end = .;
    } > RAM

    /* ---- Uninitialised data (BSS) ---- */
    .bss : {
        . = ALIGN(4);
        __bss_start = .;
        *(.bss*)
        *(COMMON)
        . = ALIGN(4);
        __bss_end = .;
    } > RAM

    /* ---- Heap (grows upward from end of BSS) ---- */
    . = ALIGN(4);
    __heap_start = .;
    . += 1048576;               /* 1 MB heap — must match HEAP_SIZE in heap.h */
    __heap_end = .;

    /* ---- Stack (allocated ABOVE heap, grows downward) ---- */
    /* stack_top is the highest address; stack grows down toward __heap_end. */
    . = ALIGN(8);
    . += 8192;                /* 8 KB stack guard space */
    stack_top = .;

    /* ---- Discard debug sections ---- */
    /DISCARD/ : {
        *(.ARM.exidx*)
        *(.comment)
    }
}
